{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orcestr Media Transcriber",
  "version": "0.1.0",
  "identifier": "com.orcestr.media-transcriber",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "devUrl": "http://localhost:8933",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* ws://localhost:8933; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "Copyright 2026 Orcestr",
    "shortDescription": "Local audio and video transcription through OpenAI.",
    "externalBin": [
      "binaries/orcestr-media-backend"
    ],
    "resources": {
      "../dist/ffmpeg/": "ffmpeg/",
      "../LICENSE": "LICENSE",
      "../THIRD_PARTY_NOTICES.md": "THIRD_PARTY_NOTICES.md"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    }
  }
}
